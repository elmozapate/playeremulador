# --- Servidor Node ---
NODE_HOST=0.0.0.0
NODE_PORT=4000
PYTHON_API_KEY=elpipidelnegro
# --- API Python ---
PYTHON_API_BASE_URL=http://127.0.0.1:8000/api/v1
PYTHON_ROOT_URL=http://127.0.0.1:8000
PYTHON_REQUEST_TIMEOUT_MS=15000

# --- Gestión del proceso Python (uvicorn) desde Node ---
# Poné en false si el servicio Python ya lo levantás vos aparte (systemd, docker, etc.)
PYTHON_MANAGE_PROCESS=true
PYTHON_BIN=C:\playeremulador\ldplayer-bridge\.venv\Scripts\python.exe
PYTHON_SRC_DIR=C:\playeremulador\ldplayer-bridge\src
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000
PYTHON_AUTOSTART=true
PYTHON_AUTORESTART=true
PYTHON_MAX_RESTARTS=5
PYTHON_RESTART_BACKOFF_MS=2000
PYTHON_READY_TIMEOUT_MS=20000
PYTHON_LOG_BUFFER_SIZE=500

# Se propagan como env vars al proceso Python al spawnearlo
LDPLAYER_PATH=C:\LDPlayer\LDPlayer9\ldconsole.exe
ADB_PATH=C:\LDPlayer\LDPlayer9\adb.exe
PY_MONITOR_INTERVAL=5
PY_HEALTH_CACHE_TTL=10
ADB_BASE_PORT=5555

# --- Polling de estado que se reenvía por SSE ---
STATUS_POLL_INTERVAL_MS=3000
